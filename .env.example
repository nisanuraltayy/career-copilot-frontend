# Bu dosyayı `.env` olarak kopyalayın. Vite yalnızca VITE_ önekli değişkenleri
# tarayıcıya expose eder.

# Backend API adresi (sonunda / olmadan).
# Lokal geliştirme: uvicorn app.main:app --reload  -> http://127.0.0.1:8000
# docker-compose kullanıyorsanız backend host portu 9000: http://127.0.0.1:9000
VITE_API_URL=http://127.0.0.1:8000
